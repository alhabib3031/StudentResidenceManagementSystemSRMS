@page "/login"
@rendermode InteractiveServer
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<PageTitle>Login - SRMS</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="d-flex align-center justify-center" Style="min-height: 100vh; padding: 20px;">
    <MudGrid Justify="Justify.Center" Style="width: 100%;">
        <MudItem xs="12" md="12" lg="10">
            <MudPaper Elevation="0" Class="login-card">
                
                <!-- Decorative Elements -->
                <div style="position: absolute; top: -100px; right: -100px; width: 300px; height: 300px; background: rgba(255,255,255,0.1); border-radius: 50%;"></div>
                <div style="position: absolute; bottom: -50px; left: -50px; width: 200px; height: 200px; background: rgba(255,255,255,0.1); border-radius: 50%;"></div>
                
                <MudGrid Style="position: relative; z-index: 1;">
                    <!-- Left Side - Branding -->
                    <MudItem xs="12" md="5" Style="padding: 48px; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center;">
                        <MudAvatar Size="Size.Large" Style="width: 120px; height: 120px; background: rgba(255,255,255,0.2); margin-bottom: 24px; backdrop-filter: blur(10px);">
                            <MudIcon Icon="@Icons.Material.Filled.School" Style="color: white; font-size: 72px;" />
                        </MudAvatar>
                        
                        <MudText Typo="Typo.h3" Style="color: white; font-weight: 800; margin-bottom: 16px; text-shadow: 0 2px 10px rgba(0,0,0,0.2);">
                            Welcome Back
                        </MudText>
                        
                        <MudText Typo="Typo.body1" Style="color: rgba(255,255,255,0.95); margin-bottom: 32px; line-height: 1.6; max-width: 300px;">
                            Sign in to access the Student Residence Management System
                        </MudText>
                        
                        <MudStack Row="false" Spacing="2" Style="width: 100%; max-width: 280px;">
                            <MudPaper Elevation="0" Style="background: rgba(255,255,255,0.15); backdrop-filter: blur(10px); padding: 16px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.2);">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.Security" Style="color: white;" />
                                    <MudText Typo="Typo.body2" Style="color: white; font-weight: 500;">Secure Login</MudText>
                                </MudStack>
                            </MudPaper>
                            
                            <MudPaper Elevation="0" Style="background: rgba(255,255,255,0.15); backdrop-filter: blur(10px); padding: 16px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.2);">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.Speed" Style="color: white;" />
                                    <MudText Typo="Typo.body2" Style="color: white; font-weight: 500;">Fast Access</MudText>
                                </MudStack>
                            </MudPaper>
                        </MudStack>
                    </MudItem>

                    <!-- Right Side - Login Form -->
                    <MudItem xs="12" md="7" Class="login-form-side">
                        <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight: 700; margin-bottom: 8px;">
                            Sign In
                        </MudText>
                        <MudText Typo="Typo.body2" Class="login-subtext">
                            Enter your credentials to continue
                        </MudText>

                        <EditForm Model="@_loginModel" OnValidSubmit="HandleLogin" FormName="LoginForm">
                            <DataAnnotationsValidator />
                            
                            <MudStack Spacing="4">
                                <!-- Email -->
                                <MudTextField 
                                    @bind-Value="_loginModel.Email"
                                    Label="Email Address"
                                    Variant="Variant.Outlined"
                                    InputType="InputType.Email"
                                    Adornment="Adornment.Start"
                                    AdornmentIcon="@Icons.Material.Filled.Email"
                                    AdornmentColor="Color.Primary"
                                    For="@(() => _loginModel.Email)"
                                    Required="true"
                                    Class="mb-2"
                                    Style="border-radius: 12px;" />

                                <!-- Password -->
                                <MudTextField 
                                    @bind-Value="_loginModel.Password"
                                    Label="Password"
                                    Variant="Variant.Outlined"
                                    InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                    Adornment="Adornment.End"
                                    AdornmentIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                    OnAdornmentClick="TogglePasswordVisibility"
                                    AdornmentColor="Color.Primary"
                                    For="@(() => _loginModel.Password)"
                                    Required="true"
                                    Style="border-radius: 12px;" />

                                <!-- Remember Me & Forgot Password -->
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudCheckBox 
                                        @bind-Value="_loginModel.RememberMe" 
                                        Color="Color.Primary"
                                        Dense="true"
                                        Label="Remember me" />
                                    
                                    <MudLink Href="/forgot-password" Color="Color.Primary" Style="font-weight: 500; text-decoration: none;">
                                        Forgot password?
                                    </MudLink>
                                </MudStack>

                                <!-- Login Button -->
                                <MudButton 
                                    ButtonType="ButtonType.Submit"
                                    Variant="Variant.Filled"
                                    Color="Color.Primary"
                                    FullWidth="true"
                                    Size="Size.Large"
                                    Disabled="_isLoading"
                                    Class="btn-modern btn-primary"
                                    Style="height: 56px;">
                                    @if (_isLoading)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" Style="color: white;" />
                                        <span>Signing in...</span>
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Login" Class="mr-2" />
                                        <span>Sign In</span>
                                    }
                                </MudButton>

                                <!-- Divider -->
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="margin: 16px 0;">
                                    <MudDivider Style="flex: 1;" />
                                    <MudText Typo="Typo.body2" Class="login-divider-text">OR</MudText>
                                    <MudDivider Style="flex: 1;" />
                                </MudStack>

                                <!-- Register Link -->
                                <MudPaper Elevation="0" Class="login-register-box">
                                    <MudText Typo="Typo.body2" Class="login-subtext" Style="margin-bottom: 12px;">
                                        Don't have an account?
                                    </MudText>
                                    <MudButton 
                                        Href="/register"
                                        Variant="Variant.Outlined"
                                        Color="Color.Primary"
                                        FullWidth="true"
                                        StartIcon="@Icons.Material.Filled.PersonAdd"
                                        Style="border-radius: 12px; text-transform: none; font-weight: 600; border-width: 2px;">
                                        Create New Account
                                    </MudButton>
                                </MudPaper>

                                <!-- Test Accounts Info -->
                                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="border-radius: 12px;">
                                    <MudText Typo="Typo.body2" Style="font-weight: 600; margin-bottom: 8px;">Test Account:</MudText>
                                    <MudText Typo="Typo.caption" Style="font-family: monospace;">
                                        Email: superroot@srms.edu.ly<br/>
                                        Password: SuperRoot@123!
                                    </MudText>
                                </MudAlert>
                            </MudStack>
                        </EditForm>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

<style>
    @@media (max-width: 960px) {
        .mud-grid > .mud-grid-item:first-child {
            display: none;
        }
    }
</style>

@code {
    private readonly LoginDto _loginModel = new();
    private bool _showPassword = false;
    private bool _isLoading = false;

    protected override void OnInitialized()
    {
        // Check if already logged in
        // Redirect to the appropriate dashboard
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    [SuppressMessage("ReSharper.DPA", "DPA0009: High execution time of DB command", MessageId = "time: 1370ms")]
    private async Task HandleLogin()
    {
        _isLoading = true;
        
        try
        {
            var result = await AuthService.LoginAsync(_loginModel);

            if (result.Success)
            {
                Snackbar.Add(
                    "Welcome back! Login successful.", 
                    Severity.Success,
                    config => 
                    { 
                        config.ShowCloseIcon = true;
                        config.VisibleStateDuration = 3000;
                    }
                );
                
                var customProvider = (CustomAuthenticationStateProvider)AuthStateProvider;
                
                await customProvider.LoginAsync(result.User!.Email);
                
                // Redirect based on the role
                var role = result.User.Roles.FirstOrDefault();
                
                var redirectUrl = role switch
                {
                    "SuperRoot" => "/superroot",
                    "Admin" => "/admin",
                    "Manager" => "/manager",
                    "Student" => "/student",
                    _ => "/"
                };
                
                await Task.Delay(500); // Small delay for UX
                Navigation.NavigateTo(redirectUrl);
            }
            else
            {
                // Show error message
                var message = result.RequiresEmailConfirmation 
                    ? "Please verify your email before logging in. Check your inbox for the verification link." 
                    : result.Message ?? "Invalid email or password. Please try again.";
                
                Snackbar.Add(
                    message, 
                    Severity.Error,
                    config => 
                    { 
                        config.ShowCloseIcon = true;
                        config.VisibleStateDuration = 5000;
                    }
                );
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AUTH_ERROR] {ex.ToString()}");
            Snackbar.Add(
                $"Login failed: {ex.Message}", 
                Severity.Error,
                config => { config.ShowCloseIcon = true; }
            );
        }
        finally
        {
            _isLoading = false;
        }
    }
}

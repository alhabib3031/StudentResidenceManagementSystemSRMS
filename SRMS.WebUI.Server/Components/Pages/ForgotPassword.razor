@page "/forgot-password"
@rendermode InteractiveServer
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Forgot Password - SRMS</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height: 100vh;">
    <MudPaper Elevation="8" Class="pa-8" Style="border-radius: 20px; width: 100%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); position: relative; overflow: hidden;">
        
        <!-- Decorative Elements -->
        <div style="position: absolute; top: -50px; right: -50px; width: 200px; height: 200px; background: rgba(255,255,255,0.1); border-radius: 50%;"></div>
        <div style="position: absolute; bottom: -30px; left: -30px; width: 150px; height: 150px; background: rgba(255,255,255,0.1); border-radius: 50%;"></div>
        
        <div style="position: relative; z-index: 1;">
            <!-- Header -->
            <div class="text-center mb-6">
                <MudAvatar Size="Size.Large" Style="width: 80px; height: 80px; background: rgba(255,255,255,0.2); margin: 0 auto 20px;">
                    <MudIcon Icon="@Icons.Material.Filled.LockReset" Size="Size.Large" Style="color: white; font-size: 48px;" />
                </MudAvatar>
                <MudText Typo="Typo.h4" Style="color: white; font-weight: 700; margin-bottom: 8px;">Forgot Password?</MudText>
                <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.9);">
                    Don't worry! Enter your email and we'll send you a reset link.
                </MudText>
            </div>

            @if (!_emailSent)
            {
                <EditForm Model="@_model" OnValidSubmit="HandleForgotPassword" FormName="ForgotPasswordForm">
                    <DataAnnotationsValidator />
                    
                    <MudCard Elevation="0" Style="background: white; border-radius: 16px; padding: 24px;">
                        <MudCardContent>
                            <MudTextField 
                                @bind-Value="_model.Email"
                                Label="Email Address"
                                Variant="Variant.Outlined"
                                InputType="InputType.Email"
                                Adornment="Adornment.Start"
                                AdornmentIcon="@Icons.Material.Filled.Email"
                                AdornmentColor="Color.Primary"
                                For="@(() => _model.Email)"
                                Required="true"
                                HelperText="Enter the email address associated with your account"
                                Style="margin-bottom: 16px;" />
                            
                            <MudButton 
                                ButtonType="ButtonType.Submit"
                                Variant="Variant.Filled"
                                Color="Color.Primary"
                                FullWidth="true"
                                Size="Size.Large"
                                Disabled="@_isLoading"
                                Style="height: 56px; border-radius: 12px; font-weight: 600; text-transform: none; font-size: 16px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                @if (_isLoading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" Style="color: white;" />
                                    <span>Sending Reset Link...</span>
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Send" Class="mr-2" />
                                    <span>Send Reset Link</span>
                                }
                            </MudButton>
                        </MudCardContent>
                    </MudCard>
                </EditForm>

                <!-- Back to Login -->
                <div class="text-center mt-4">
                    <MudButton 
                        Href="/login" 
                        Variant="Variant.Text" 
                        StartIcon="@Icons.Material.Filled.ArrowBack"
                        Style="color: white; text-transform: none; font-weight: 500;">
                        Back to Login
                    </MudButton>
                </div>
            }
            else
            {
                <!-- Success Message -->
                <MudCard Elevation="0" Style="background: white; border-radius: 16px; padding: 32px; text-align: center;">
                    <MudCardContent>
                        <MudIcon Icon="@Icons.Material.Filled.MarkEmailRead" Size="Size.Large" Style="color: #10b981; font-size: 72px; margin-bottom: 16px;" />
                        <MudText Typo="Typo.h5" Style="color: #1f2937; font-weight: 600; margin-bottom: 12px;">
                            Check Your Email
                        </MudText>
                        <MudText Typo="Typo.body1" Style="color: #6b7280; margin-bottom: 24px;">
                            We've sent a password reset link to <strong>@_model.Email</strong>
                        </MudText>
                        <MudText Typo="Typo.body2" Style="color: #9ca3af; margin-bottom: 24px;">
                            Didn't receive the email? Check your spam folder or try again.
                        </MudText>
                        
                        <MudButton 
                            Variant="Variant.Outlined" 
                            Color="Color.Primary"
                            OnClick="ResetForm"
                            Style="border-radius: 12px; text-transform: none; font-weight: 500; margin-right: 8px;">
                            Try Another Email
                        </MudButton>
                        
                        <MudButton 
                            Href="/login" 
                            Variant="Variant.Filled"
                            Color="Color.Primary"
                            Style="border-radius: 12px; text-transform: none; font-weight: 500; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                            Back to Login
                        </MudButton>
                    </MudCardContent>
                </MudCard>
            }
        </div>
    </MudPaper>
</MudContainer>

@code {
    private ForgotPasswordDto _model = new();
    private bool _isLoading = false;
    private bool _emailSent = false;

    private async Task HandleForgotPassword()
    {
        _isLoading = true;

        try
        {
            var result = await AuthService.ForgotPasswordAsync(_model);

            if (result)
            {
                _emailSent = true;
                Snackbar.Add(
                    "Password reset link sent successfully! Please check your email.",
                    Severity.Success,
                    config => 
                    { 
                        config.VisibleStateDuration = 5000;
                        config.ShowCloseIcon = true;
                    }
                );
            }
            else
            {
                Snackbar.Add(
                    "Failed to send reset link. Please try again.",
                    Severity.Error,
                    config => { config.ShowCloseIcon = true; }
                );
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                $"An error occurred: {ex.Message}",
                Severity.Error,
                config => { config.ShowCloseIcon = true; }
            );
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ResetForm()
    {
        _emailSent = false;
        _model = new ForgotPasswordDto();
    }
}

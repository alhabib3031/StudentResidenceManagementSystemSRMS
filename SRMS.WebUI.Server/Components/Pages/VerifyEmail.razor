@page "/verify-email"
@rendermode InteractiveServer
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using Microsoft.AspNetCore.WebUtilities

<PageTitle>Email Verification - SRMS</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="min-height: 100vh; padding: 20px;">
    <MudPaper Elevation="0" Style="border-radius: 20px; width: 100%; background: #1e1b2e; padding: 40px; position: relative; overflow: hidden;">
        
        <!-- Decorative Background Elements -->
        <div style="position: absolute; top: -100px; right: -100px; width: 300px; height: 300px; background: radial-gradient(circle, rgba(103, 58, 183, 0.2) 0%, transparent 70%); border-radius: 50%;"></div>
        <div style="position: absolute; bottom: -80px; left: -80px; width: 250px; height: 250px; background: radial-gradient(circle, rgba(233, 30, 99, 0.2) 0%, transparent 70%); border-radius: 50%;"></div>
        
        <div style="position: relative; z-index: 1;">
            <!-- Header -->
            <div class="text-center mb-6">
                <MudText Typo="Typo.h3" Style="color: white; font-weight: 700; margin-bottom: 8px;">
                    Email Verification
                </MudText>
            </div>

            @if (_isLoading)
            {
                <!-- Loading State -->
                <MudCard Elevation="4" Style="background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.1); padding: 48px; text-align: center;">
                    <MudCardContent>
                        <MudProgressCircular 
                            Indeterminate="true" 
                            Size="Size.Large" 
                            Style="color: #bb86fc; margin-bottom: 24px;" />
                        <MudText Typo="Typo.h6" Style="color: white; margin-bottom: 8px;">
                            Verifying Your Email
                        </MudText>
                        <MudText Typo="Typo.body2" Style="color: rgba(255, 255, 255, 0.7);">
                            Please wait while we verify your account...
                        </MudText>
                    </MudCardContent>
                </MudCard>
            }
            else if (_verificationSuccess)
            {
                <!-- Success State -->
                <MudCard Elevation="4" Style="background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.1); padding: 48px; text-align: center;">
                    <MudCardContent>
                        <div style="width: 100px; height: 100px; background: linear-gradient(135deg, #10b981 0%, #059669 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; box-shadow: 0 10px 30px rgba(16, 185, 129, 0.3);">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color: white; font-size: 60px;" />
                        </div>
                        
                        <MudText Typo="Typo.h4" Style="color: white; font-weight: 700; margin-bottom: 12px;">
                            Verification Successful!
                        </MudText>
                        
                        <MudText Typo="Typo.body1" Style="color: rgba(255, 255, 255, 0.8); margin-bottom: 32px; line-height: 1.6;">
                            Your email has been verified successfully. Welcome to the Student Residence Management System!
                        </MudText>
                        
                        <MudButton 
                            Variant="Variant.Filled"
                            Color="Color.Success"
                            Size="Size.Large"
                            OnClick="GoToLogin"
                            StartIcon="@Icons.Material.Filled.Login"
                            Style="border-radius: 12px; text-transform: none; font-weight: 600; font-size: 16px; padding: 12px 32px; background: linear-gradient(135deg, #10b981 0%, #059669 100%); box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);">
                            Login Now
                        </MudButton>
                    </MudCardContent>
                </MudCard>
            }
            else
            {
                <!-- Error State (matching the image design) -->
                <MudCard Elevation="4" Style="background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border-radius: 16px; border: 1px solid rgba(255, 255, 255, 0.1); padding: 48px; text-align: center;">
                    <MudCardContent>
                        <!-- Error Alert Box -->
                        <MudAlert 
                            Severity="Severity.Error" 
                            Variant="Variant.Filled"
                            Icon="@Icons.Material.Filled.ErrorOutline"
                            Style="background: #ef4444; border-radius: 12px; margin-bottom: 24px; font-weight: 600; font-size: 16px; padding: 16px;">
                            Verification Failed
                        </MudAlert>
                        
                        <!-- Error Message -->
                        <MudText 
                            Typo="Typo.body1" 
                            Style="color: #ef4444; margin-bottom: 32px; font-size: 16px; line-height: 1.6;">
                            @_errorMessage
                        </MudText>
                        
                        <!-- Try Again Button -->
                        <MudButton 
                            Variant="Variant.Filled"
                            Color="Color.Error"
                            Size="Size.Large"
                            FullWidth="true"
                            OnClick="GoToRegister"
                            Style="border-radius: 12px; text-transform: uppercase; font-weight: 700; font-size: 16px; padding: 16px; background: #ef4444; box-shadow: 0 4px 15px rgba(239, 68, 68, 0.4); letter-spacing: 0.5px;">
                            TRY REGISTERING AGAIN
                        </MudButton>
                        
                        <!-- Additional Help -->
                        <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid rgba(255, 255, 255, 0.1);">
                            <MudText Typo="Typo.body2" Style="color: rgba(255, 255, 255, 0.6); margin-bottom: 16px;">
                                Need help? Contact support or try these options:
                            </MudText>
                            
                            <MudStack Row="true" Justify="Justify.Center" Spacing="2">
                                <MudButton 
                                    Variant="Variant.Outlined"
                                    Color="Color.Default"
                                    OnClick="GoToLogin"
                                    StartIcon="@Icons.Material.Filled.Login"
                                    Style="border-radius: 8px; text-transform: none; border-color: rgba(255, 255, 255, 0.3); color: white;">
                                    Back to Login
                                </MudButton>
                                
                                <MudButton 
                                    Variant="Variant.Outlined"
                                    Color="Color.Default"
                                    Href="mailto:support@srms.com"
                                    StartIcon="@Icons.Material.Filled.Email"
                                    Style="border-radius: 8px; text-transform: none; border-color: rgba(255, 255, 255, 0.3); color: white;">
                                    Contact Support
                                </MudButton>
                            </MudStack>
                        </div>
                    </MudCardContent>
                </MudCard>
            }
        </div>
    </MudPaper>
</MudContainer>

<style>
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .mud-card {
        animation: fadeIn 0.5s ease-out;
    }
</style>

@code {
    private bool _isLoading = true;
    private bool _verificationSuccess = false;
    private string _errorMessage = "Email verification failed. The token might be invalid or expired.";

    protected override async Task OnInitializedAsync()
    {
        // Parse the URL to get userId and code
        var uri = new Uri(Navigation.Uri);
        var queryParams = QueryHelpers.ParseQuery(uri.Query);

        if (queryParams.TryGetValue("userId", out var userId) && queryParams.TryGetValue("code", out var code))
        {
            try
            {
                // Decode the token since it was URL-encoded when sent via email
                var decodedToken = System.Net.WebUtility.UrlDecode(code!);
                
                var dto = new VerifyEmailDto
                {
                    UserId = Guid.Parse(userId!),
                    Token = decodedToken
                };

                // Call the authentication service to verify email
                var result = await AuthService.VerifyEmailAsync(dto);

                if (result)
                {
                    _verificationSuccess = true;
                    Snackbar.Add(
                        "Email verified successfully! Welcome to SRMS.",
                        Severity.Success,
                        config => 
                        { 
                            config.VisibleStateDuration = 5000;
                            config.ShowCloseIcon = true;
                        }
                    );
                    
                    // Auto-redirect after 5 seconds
                    _ = Task.Delay(5000).ContinueWith(_ => 
                    {
                        InvokeAsync(() => GoToLogin());
                    });
                }
                else
                {
                    _errorMessage = "Email verification failed. The token might be invalid or expired.";
                }
            }
            catch (FormatException)
            {
                _errorMessage = "Invalid verification link format. Please check the link and try again.";
            }
            catch (Exception ex)
            {
                _errorMessage = $"An error occurred during verification: {ex.Message}";
            }
        }
        else
        {
            _errorMessage = "Invalid verification link. Required information is missing from the URL.";
        }

        _isLoading = false;
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private void GoToRegister()
    {
        Navigation.NavigateTo("/register");
    }
}

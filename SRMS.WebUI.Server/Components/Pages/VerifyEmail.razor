@page "/verify-email"
@rendermode InteractiveServer
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using Microsoft.AspNetCore.WebUtilities

<PageTitle>Verifying Email...</PageTitle>

<MudPaper Elevation="8" Class="pa-8" Style="border-radius: 16px; max-width: 600px; margin: 40px auto;">
    <MudText Typo="Typo.h5" Align="Align.Center" GutterBottom="true">Email Verification</MudText>
    
    @if (_isLoading)
    {
        <MudText Align="Align.Center">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Class="mb-4" />
            <br />
            Verifying your account, please wait...
        </MudText>
    }
    else if (_verificationSuccess)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Class="mb-4">
            Verification successful! Welcome to SRMS.
        </MudAlert>
        <MudText Align="Align.Center" Class="mb-4">
            Your email has been verified. You will be redirected to the login page shortly.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="GoToLogin">
            Login Now
        </MudButton>
    }
    else
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-4">
            Verification Failed
        </MudAlert>
        <MudText Align="Align.Center" Color="Color.Error" Class="mb-4">
            @(_errorMessage)
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Error" FullWidth="true" OnClick="GoToRegister">
            Try Registering Again
        </MudButton>
    }
</MudPaper>

@code {
    private bool _isLoading = true;
    private bool _verificationSuccess = false;
    private string _errorMessage = "Invalid verification link. The link may be expired or incorrect.";

    protected override async Task OnInitializedAsync()
    {
        // 1. قراءة الرابط الحالي
        var uri = new Uri(Navigation.Uri);
        
        // 2. استخراج الباراميترز (userId و code) من الرابط
        var queryParams = QueryHelpers.ParseQuery(uri.Query);

        if (queryParams.TryGetValue("userId", out var userId) && queryParams.TryGetValue("code", out var code))
        {
            try
            {
                // 3. [مهم جداً] فك تشفير التوكن (عكس عملية الـ UrlEncode)
                // الـ DTO يتوقع التوكن الأصلي
                var decodedToken = System.Net.WebUtility.UrlDecode(code);

                var dto = new VerifyEmailDto
                {
                    UserId = Guid.Parse(userId!),
                    Token = decodedToken!
                };

                // 4. استدعاء خدمة المصادقة لتأكيد البريد
                var result = await AuthService.VerifyEmailAsync(dto);

                if (result)
                {
                    _verificationSuccess = true;
                    Snackbar.Add("Email verified successfully! Welcome.", Severity.Success);
                    // إعادة توجيه المستخدم لصفحة الدخول بعد 5 ثوان
                    _ = Task.Delay(5000).ContinueWith(_ => GoToLogin());
                }
                else
                {
                    _errorMessage = "Email verification failed. The token might be invalid or expired.";
                }
            }
            catch (Exception ex)
            {
                _errorMessage = $"An error occurred: {ex.Message}";
            }
        }
        else
        {
            _errorMessage = "Invalid verification link. Required information is missing.";
        }

        _isLoading = false;
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private void GoToRegister()
    {
        Navigation.NavigateTo("/register");
    }
}
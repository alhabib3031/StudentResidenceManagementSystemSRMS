@page "/student/profile"
@attribute [Authorize(Roles = "Student")]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<PageTitle>My Profile</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">
    <!-- Header -->
    <MudPaper Elevation="0" Class="p-4 mb-4">
        <MudText Typo="Typo.h4" Color="Color.Primary">
            <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" />
            My Profile
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            View and manage your personal information
        </MudText>
    </MudPaper>

    <MudGrid>
        <!-- Profile Picture Card -->
        <MudItem xs="12" md="4">
            <MudCard Elevation="4">
                <MudCardContent Class="text-center">
                    <MudAvatar Size="Size.Large" Class="w-[150px] h-[150px] mx-auto">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Large" />
                    </MudAvatar>
                    <MudText Typo="Typo.h5" Class="mt-4">@_userName</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Student</MudText>

                    <MudDivider Class="my-4" />

                    <MudChip T="string" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">
                        Active Student
                    </MudChip>

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                        StartIcon="@Icons.Material.Filled.CloudUpload" Class="mt-4" OnClick="@UploadPhoto">
                        Upload Photo
                    </MudButton>
                </MudCardContent>
            </MudCard>

            <!-- Quick Stats -->
            <MudCard Elevation="4" Class="mt-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Quick Stats</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudStack Spacing="3">
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Member Since</MudText>
                            <MudText Typo="Typo.body2"><strong>January 2024</strong></MudText>
                        </div>
                        <MudDivider />
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Total Payments</MudText>
                            <MudText Typo="Typo.body2"><strong>12 Payments</strong></MudText>
                        </div>
                        <MudDivider />
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Complaints</MudText>
                            <MudText Typo="Typo.body2"><strong>3 Total (1 Active)</strong></MudText>
                        </div>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Profile Information -->
        <MudItem xs="12" md="8">
            <MudTabs Elevation="4" Rounded="true" ApplyEffectsToContainer="true" PanelClass="p-6">
                <!-- Personal Info Tab -->
                <MudTabPanel Text="Personal Info" Icon="@Icons.Material.Filled.Person">
                    <EditForm Model="@_profileModel" OnValidSubmit="SaveProfile">
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_profileModel.FirstName" Label="First Name"
                                    Variant="Variant.Outlined" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_profileModel.LastName" Label="Last Name"
                                    Variant="Variant.Outlined" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_profileModel.Email" Label="Email" Variant="Variant.Outlined"
                                    InputType="InputType.Email" Required="true" Disabled="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_profileModel.PhoneNumber" Label="Phone Number"
                                    Variant="Variant.Outlined" Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="_profileModel.NationalId" Label="National ID"
                                    Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudDatePicker @bind-Date="_profileModel.DateOfBirth" Label="Date of Birth"
                                    Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                                    StartIcon="@Icons.Material.Filled.Save" Disabled="_isSaving">
                                    @if (_isSaving)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                        <span>Saving...</span>
                                    }
                                    else
                                    {
                                        <span>Save Changes</span>
                                    }
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                    </EditForm>
                </MudTabPanel>

                <!-- Academic Info Tab -->
                <MudTabPanel Text="Academic Info" Icon="@Icons.Material.Filled.School">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_profileModel.UniversityName" Label="University Name"
                                Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_profileModel.StudentNumber" Label="Student Number"
                                Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_profileModel.Major" Label="Major" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudNumericField @bind-Value="_profileModel.AcademicYear" Label="Academic Year"
                                Variant="Variant.Outlined" Min="1" Max="6" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                StartIcon="@Icons.Material.Filled.Save" OnClick="SaveProfile">
                                Save Changes
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                <!-- Address Tab -->
                <MudTabPanel Text="Address" Icon="@Icons.Material.Filled.Home">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_profileModel.City" Label="City" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_profileModel.State" Label="State" Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_profileModel.Street" Label="Street Address"
                                Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_profileModel.PostalCode" Label="Postal Code"
                                Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_profileModel.Country" Label="Country"
                                Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                StartIcon="@Icons.Material.Filled.Save" OnClick="SaveProfile">
                                Save Changes
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                <!-- Emergency Contact Tab -->
                <MudTabPanel Text="Emergency Contact" Icon="@Icons.Material.Filled.ContactPhone">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_profileModel.EmergencyContactName" Label="Contact Name"
                                Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_profileModel.EmergencyContactPhone" Label="Contact Phone"
                                Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_profileModel.EmergencyContactRelation" Label="Relationship"
                                Variant="Variant.Outlined" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                StartIcon="@Icons.Material.Filled.Save" OnClick="SaveProfile">
                                Save Changes
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                <!-- Security Tab -->
                <MudTabPanel Text="Security" Icon="@Icons.Material.Filled.Security">
                    <MudGrid>
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Info" Dense="true">
                                Change your password to keep your account secure
                            </MudAlert>
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField T="string" Label="Current Password" Variant="Variant.Outlined"
                                InputType="InputType.Password" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField T="string" Label="New Password" Variant="Variant.Outlined"
                                InputType="InputType.Password" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField T="string" Label="Confirm New Password" Variant="Variant.Outlined"
                                InputType="InputType.Password" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                StartIcon="@Icons.Material.Filled.Lock" OnClick="ChangePassword">
                                Change Password
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>
            </MudTabs>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private string _userName = "Student";
    private bool _isSaving = false;
    private ProfileModel _profileModel = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            _userName = user.Identity.Name ?? "Student";
        }

        // TODO: Load real profile data
        _profileModel = new ProfileModel
            {
                FirstName = "John",
                LastName = "Doe",
                Email = "john.doe@example.com",
                PhoneNumber = "+218 91 234 5678"
            };
    }

    private async Task SaveProfile()
    {
        _isSaving = true;
        try
        {
            await Task.Delay(1000); // Simulate API call
            Snackbar.Add("Profile updated successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void UploadPhoto()
    {
        Snackbar.Add("Upload photo functionality - Coming soon!", Severity.Info);
    }

    private void ChangePassword()
    {
        Snackbar.Add("Change password functionality - Coming soon!", Severity.Info);
    }

    public class ProfileModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string Email { get; set; } = "";
        public string? PhoneNumber { get; set; }
        public string? NationalId { get; set; }
        public DateTime? DateOfBirth { get; set; }
        public string? UniversityName { get; set; }
        public string? StudentNumber { get; set; }
        public string? Major { get; set; }
        public int? AcademicYear { get; set; }
        public string? City { get; set; }
        public string? State { get; set; }
        public string? Street { get; set; }
        public string? PostalCode { get; set; }
        public string? Country { get; set; } = "Libya";
        public string? EmergencyContactName { get; set; }
        public string? EmergencyContactPhone { get; set; }
        public string? EmergencyContactRelation { get; set; }
    }
}